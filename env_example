# Скопируйте в .env и заполните значения:
#   cp env_example .env

# Токен бота от @BotFather
BOT_TOKEN=123456:YOUR_BOT_TOKEN

# ID целевого чата (супергруппы), куда пользователи подают заявку.
# Узнать можно через @userinfobot или @getidsbot — для групп ID обычно отрицательный.
TARGET_CHAT_ID=-1001234567890

# Версии документов онбординга (меняйте при обновлении текстов в texts.py)
RULES_VERSION=1.0
LETTER_VERSION=1.0
PD_VERSION=1.0

# 1 — пробовать отправлять Telegram Rich Messages (Bot API sendRichMessage)
# 0 — использовать обычные HTML-сообщения aiogram
USE_RICH_MESSAGES=1

# Путь к SQLite-базе (по умолчанию bot.db в корне проекта).
# В Docker Compose задаётся автоматически: /app/data/bot.db
# DB_PATH=bot.db
